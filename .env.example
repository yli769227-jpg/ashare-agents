# OpenAI API key (only needed for real LLM calls; tests use a fake LLM).
OPENAI_API_KEY=

# Model name (defaults to gpt-4o-mini if unset).
ASHARE_AGENTS_MODEL=gpt-4o-mini

# Force fake-LLM mode even when OPENAI_API_KEY is set (used by tests).
# Set to "1" to enable.
ASHARE_AGENTS_FAKE_LLM=0

# Override location of the ashare-mcp install (only needed if not pip-installed).
# Default: imported as a normal package via pyproject.toml dependency.
ASHARE_MCP_PATH=
